# === 上游渠道 ===
UPSTREAM_BASE_URL=https://api.example.com/v1
UPSTREAM_API_KEY=your-api-key-here
UPSTREAM_MODEL=your-model-name

# === 本服务 ===
LISTEN_PORT=8787
# 客户端访问本服务时用的密码，自己生成一串随机字符
AUTH_TOKEN=请替换为随机32位以上字符串

# === 输入分块阈值（token）===
CHUNK_TARGET_TOKENS=2000
CHUNK_HARD_LIMIT=2500

# === 输出截断阈值（token）===
# < 9000：完全直通，原文一字不动
# >= 9000：开始找安全切点（\n + 干净状态）
# >= 9500：兜底强切
OUTPUT_SOFT_CUT=9000
OUTPUT_HARD_CUT=9500
MAX_CONTINUATIONS=20

# === 日志 ===
LOG_LEVEL=info
LOG_PROMPTS=false
